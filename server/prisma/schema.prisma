generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  vipLevel  Int      @default(0)
  totalSpent Float   @default(0)
  orders    Order[]
  createdAt DateTime @default(now())
}

model Product {
  id          Int     @id
  name        String
  price       Float
  oldPrice    Float?
  image       String?
  rating      Float?
  sold        Int?
  stock       Int?
  category    String?
  brand       String?
  featured    Boolean @default(false)
  description String?
}

model Order {
  id         Int         @id @default(autoincrement())
  user       User?       @relation(fields: [userId], references: [id])
  userId     Int?
  total      Float
  discount   Float?
  createdAt  DateTime    @default(now())
  items      OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   Int
  productId Int
  name      String
  price     Float
  quantity  Int
}
